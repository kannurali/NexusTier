@echo off
rem ===== Nexus Tier List - запуск редактора =====
rem Поднимает локальный сервер и открывает редактор в браузере.
rem Локальный сервер нужен, чтобы работала кнопка "Скачать PNG"
rem (браузер блокирует экспорт картинок при открытии файлом file://).

cd /d "%~dp0"

echo Запускаю локальный сервер на http://127.0.0.1:8780 ...
start "Nexus Tier List server" cmd /c python -m http.server 8780 --bind 127.0.0.1

rem небольшая пауза, чтобы сервер успел стартовать
timeout /t 1 >nul

start "" http://127.0.0.1:8780/

echo.
echo Готово! Редактор открыт в браузере.
echo Чтобы остановить сервер - закройте окно "Nexus Tier List server".
echo.
